# ════════════════════════════════════════════════
# SOLUCIONES ACADÉMICAS LOMBANA — Variables de entorno
# ════════════════════════════════════════════════
# Copia este archivo como .env y completa los valores

# ─── SERVIDOR ──────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── BASE DE DATOS ─────────────────────────────
# PostgreSQL connection string
# Formato: postgresql://usuario:contraseña@host:5432/nombre_bd
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/lombana_db

# Ejemplo Railway:
# DATABASE_URL=postgresql://postgres:AbCdEf@containers-us-west-xxx.railway.app:7654/railway

# Ejemplo Supabase:
# DATABASE_URL=postgresql://postgres.xxxx:contraseña@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── SEGURIDAD ─────────────────────────────────
# Clave secreta para JWT — usa una cadena aleatoria larga
JWT_SECRET=CambiaEstaClaveSecretaPorUnaAleatoriaLarga2026_$ecure!

# ─── CORS ──────────────────────────────────────
# URL de tu dominio frontend (sin slash final)
FRONTEND_URL=https://tudominio.com
